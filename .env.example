# Copy this file to .env and fill real production values.
# Do not commit .env.

# Optional: public HTTPS base URL used for deployment checks and external integrations.
EXTERNAL_API_BASE_URL=https://api.speedasia.net
CLOUDFLARED_TUNNEL_TOKEN=
# CLOUDFLARED_PUBLIC_HOSTNAME=api.speedasia.net
CLOUDFLARED_PUBLIC_HOSTNAME=
CLOUDFLARED_TARGET_URL=http://localhost:8071
CLOUDFLARED_BIN=
CLOUDFLARED_LOG_FILE=logs/cloudflared.log
ENABLE_LOCAL_HTTPS=false
LOCAL_HTTPS_CERT_FILE=backend/certs/localhost-cert.pem
LOCAL_HTTPS_KEY_FILE=backend/certs/localhost-key.pem

# Optional: WeCom app. Required only for callback verification or app card/message sending.
CORP_ID=
CORP_SECRET=
AGENT_ID=
TOKEN=
ENCODING_AES_KEY=

# Optional: WeCom chat archive. Required only for syncing real chat archive messages.
CHATDATA_SECRET=
PRIVATE_KEY_PATH=backend/private_key.pem
ENABLE_ARCHIVE_POLLING=false
PUBLIC_KEY_VER=2

# Optional: WeCom reply advance-completion postprocessor.
# When enabled, sidebar_assist rewrites generated LLM2/train_ai drafts in-process before returning blind-eval replies.
WECOM_ADVANCE_COMPLETION_ENABLED=false
WECOM_ADVANCE_COMPLETION_PROVIDER=hybrid
WECOM_ADVANCE_COMPLETION_OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat
WECOM_ADVANCE_COMPLETION_LOCAL_MODEL=unsloth-qwen2.5-task-62:latest
WECOM_ADVANCE_COMPLETION_TIMEOUT_SECONDS=70

# Required: PostgreSQL knowledge-base database.
# Optional: full SQLAlchemy URL. If set, it takes precedence over DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DATABASE_CONNECT_TIMEOUT_SECONDS=15
DATABASE_STATEMENT_TIMEOUT_MS=20000
DATABASE_IDLE_IN_TRANSACTION_TIMEOUT_MS=60000
DATABASE_LOCK_TIMEOUT_MS=5000

# LLM-1: structured extraction. Use a Dify app key (app-...) for Dify.
LLM1_API_URL=http://zjsphs.2288.org:11599/v1
LLM1_API_KEY=
LLM1_MODEL=qwen14b
LLM1_TIMEOUT_SECONDS=100
LLM1_MAX_TOKENS=700
LLM1_COMPARE_API_URL=http://zjsphs.2288.org:11599/v1
LLM1_COMPARE_API_KEY=
LLM1_COMPARE_MODEL=qwen-plus
LLM1_COMPARE_TIMEOUT_SECONDS=100

# LLM-2: primary sales assist.
LLM2_API_URL=https://api.deepseek.com
LLM2_API_KEY=
LLM2_MODEL=deepseek-chat
LLM2_TIMEOUT_SECONDS=100

# Optional Training AI model list/chat. Keep model-list timeout short to avoid freezing first page load.
TRAIN_AI_ENABLED=true
TRAIN_AI_BASE_URL=http://zjsphs.2288.org:11486
TRAIN_AI_API_KEY=
TRAIN_AI_MODEL=unsloth-qwen2.5-task-60
TRAIN_AI_TIMEOUT_SECONDS=10
TRAIN_AI_MODEL_LIST_TIMEOUT_SECONDS=2
TRAIN_AI_MAX_TOKENS=300

# Mail draft LLM provider. deepseek reuses LLM2_*; openai uses MAIL_DRAFT_OPENAI_*.
MAIL_DRAFT_LLM_PROVIDER=deepseek
MAIL_DRAFT_LLM_TEMPERATURE=0.55
MAIL_DRAFT_LLM_MAX_TOKENS=1800
MAIL_DRAFT_OPENAI_API_URL=https://api.openai.com/v1/chat/completions
MAIL_DRAFT_OPENAI_API_KEY=
MAIL_DRAFT_OPENAI_MODEL=gpt-4o-mini
MAIL_DRAFT_OPENAI_TIMEOUT_SECONDS=60
# Optional alias supported by legacy recording parser config.
RECORDING_PARSE_OPENAI_VISION_API_URL=
RECORDING_PARSE_OPENAI_VISION_API_KEY=

# LLM-2 comparison: optional second sales-assist output. Use a separate Dify app key.
LLM2_COMPARE_API_URL=http://zjsphs.2288.org:11599/v1
LLM2_COMPARE_API_KEY=
LLM2_COMPARE_MODEL=qwen3-480b-cloud
LLM2_COMPARE_TIMEOUT_SECONDS=100
API_REPLY_SINGLE_MODEL_SINGLE_STYLE=true
API_REPLY_ENABLE_SCORING=false

# Embedding via Dify app. Keep this app key separate from LLM app keys.
EMBEDDING_PROVIDER=dify
EMBEDDING_API_URL=http://zjsphs.2288.org:11599
EMBEDDING_API_KEY=
EMBEDDING_MODEL=qllama/bge-m3:latest
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=100

# Optional: CRM SQL Server. Read-only auxiliary context, not used for knowledge-base storage.
CRM_DBHost=
CRM_DBPort=1433
CRM_DBName=
CRM_DBUserId=
CRM_DBPassword=
CRM_ODBC_DRIVER=ODBC Driver 18 for SQL Server
CRM_DB_ENCRYPT=false
CRM_DB_TRUST_SERVER_CERTIFICATE=true
CRM_DB_CONNECTION_TIMEOUT=100

# Runtime
HTTP_TRUST_ENV=false
FRONTEND_AUTH_ENABLED=true
FRONTEND_AUTH_USERNAME=admin
FRONTEND_AUTH_PASSWORD=Qw@2026
# Optional extra frontend users. Format: username:password:role,username2:password2:role2
FRONTEND_AUTH_EXTRA_USERS=hj:123456:mail_quality_only
# Optional: set a long random value in production to invalidate old login cookies.
FRONTEND_AUTH_SECRET=
FRONTEND_AUTH_SESSION_SECONDS=86400
SALES_KB_API_BASE_URL=https://knowledgebase.speedasia.net
LOG_LLM_PROMPTS=true
LOG_DESENSITIZE_ENABLED=true
SLOW_REQUEST_MS=3000

# 邮件 .eml 上传 SFTP(老 SSH，需 paramiko<4)
FTP_HOST=
FTP_PORT=1575
FTP_USERID=
FTP_PASSWORD=
