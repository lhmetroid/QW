# Copy this file to .env and fill real production values.
# Do not commit .env.

# Optional: public HTTPS base URL used for deployment checks and external integrations.
EXTERNAL_API_BASE_URL=https://speedforce.cycleforce.cc
CLOUDFLARED_TUNNEL_TOKEN=
CLOUDFLARED_PUBLIC_HOSTNAME=speedforce.cycleforce.cc
CLOUDFLARED_TARGET_URL=https://localhost:8016
CLOUDFLARED_BIN=
CLOUDFLARED_LOG_FILE=logs/cloudflared.log
ENABLE_LOCAL_HTTPS=true
LOCAL_HTTPS_CERT_FILE=backend/certs/localhost-cert.pem
LOCAL_HTTPS_KEY_FILE=backend/certs/localhost-key.pem

# Optional: WeCom app. Required only for callback verification or app card/message sending.
CORP_ID=
CORP_SECRET=
AGENT_ID=
TOKEN=
ENCODING_AES_KEY=

# Optional: WeCom chat archive. Required only for syncing real chat archive messages.
CHATDATA_SECRET=
PRIVATE_KEY_PATH=backend/private_key.pem
ENABLE_ARCHIVE_POLLING=false
PUBLIC_KEY_VER=2

# Required: PostgreSQL knowledge-base database.
# Optional: full SQLAlchemy URL. If set, it takes precedence over DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# LLM-1: structured extraction. Use a Dify app key (app-...) for Dify.
LLM1_API_URL=http://10.0.0.210:89/v1
LLM1_API_KEY=
LLM1_MODEL=qwen14b
LLM1_TIMEOUT_SECONDS=100
LLM1_COMPARE_API_URL=http://10.0.0.210:89/v1
LLM1_COMPARE_API_KEY=
LLM1_COMPARE_MODEL=qwen-plus
LLM1_COMPARE_TIMEOUT_SECONDS=100

# LLM-2: primary sales assist.
LLM2_API_URL=https://api.deepseek.com
LLM2_API_KEY=
LLM2_MODEL=deepseek-chat
LLM2_TIMEOUT_SECONDS=100

# LLM-2 comparison: optional second sales-assist output. Use a separate Dify app key.
LLM2_COMPARE_API_URL=http://10.0.0.210:89/v1
LLM2_COMPARE_API_KEY=
LLM2_COMPARE_MODEL=qwen3-480b-cloud
LLM2_COMPARE_TIMEOUT_SECONDS=100
API_REPLY_SINGLE_MODEL_SINGLE_STYLE=true
API_REPLY_ENABLE_SCORING=false

# Ollama embedding
EMBEDDING_PROVIDER=ollama
EMBEDDING_API_URL=http://127.0.0.1:11434
EMBEDDING_MODEL=qllama/bge-m3:latest
EMBEDDING_DIM=1024
EMBEDDING_TIMEOUT_SECONDS=100

# Optional: CRM SQL Server. Read-only auxiliary context, not used for knowledge-base storage.
CRM_DBHost=
CRM_DBPort=1433
CRM_DBName=
CRM_DBUserId=
CRM_DBPassword=
CRM_ODBC_DRIVER=ODBC Driver 18 for SQL Server
CRM_DB_ENCRYPT=false
CRM_DB_TRUST_SERVER_CERTIFICATE=true
CRM_DB_CONNECTION_TIMEOUT=100

# Runtime
HTTP_TRUST_ENV=false
LOG_LLM_PROMPTS=true
LOG_DESENSITIZE_ENABLED=true
SLOW_REQUEST_MS=3000
