e0d\u5199\u89e3\u91ca\u8fc7\u7a0b\u3002\n\n\u3010\u4f01\u5fae\u5bf9\u8bdd\u5b9e\u5f55\u3011:\n[\u9500\u552e]: \u6211\u53d6\u548c\u8d22\u52a1\u7533\u8bf7\u4e0b\u54e6\uff0c\u770b\u770b\u5979\u600e\u4e48\u8bf4\uff0c\u8fd9\u4e2a\u6211\u4e5f\u505a\u4e0d\u4e86\u4e3b\n[\u5ba2\u6237]: \u4f60\u518d\u7533\u8bf7\u4e0b\u5427\n[\u5ba2\u6237]: \u7b7e\u5b9a\u672c\u670d\u52a1\u5408\u540c\u540e\uff0c\u82e5\u53d6\u6d88\u53e3\u8bd1\u670d\u52a1\uff0c\u5219\u81f3\u5c11\u9700\u8981\u652f\u4ed8\u670d\u52a1\u8d39\u603b\u989d\u768470%\u6216\u4ee5\u4e0a\u3002\n[\u5ba2\u6237]: \u8fd9\u6761\u5efa\u8bae\u52a0\u4e0a\u65f6\u95f4\uff0c\u63d0\u524d\u4e00\u5468\uff1f\n[\u5ba2\u6237]: \u652f\u4ed8\u603b\u989d50%\n[\u5ba2\u6237]: \u53e6\u5916\u5982\u679c\u7ffb\u8bd1\u4eba\u5458\u8fdd\u7ea6\u5462\uff1f\n[\u5ba2\u6237]: \u53cc\u65b9\u53ef\u80fd\u90fd\u8981\u89c4\u5b9a\u4e0b\u8fdd\u7ea6\u8d23\u4efb\u5427\n[\u9500\u552e]: \u7ffb\u8bd1\u9664\u4e0d\u53ef\u6297\u529b\uff0c\u4e0d\u4f1a\u6709\u95ee\u9898\u54c8\uff0c\u53ef\u4ee5\u52a0\u6ef4\n[\u9500\u552e]: \u6587\u5b57\u53ef\u4ee5\u5199\u7ed9\u6211\uff0c\u4e00\u8d77\u6539\u54e6\n[\u5ba2\u6237]: \uff081\uff09??? \u7b7e\u5b9a\u672c\u670d\u52a1\u5408\u540c\u540e\uff0c\u9664\u4e0d\u53ef\u6297\u529b\u5916\uff0c\u5982\u9700\u53d6\u6d88\u53e3\u8bd1\u670d\u52a1\uff0c\u53cc\u65b9\u5fc5\u987b\u81f3\u5c11\u63d0\u524d\u4e00\u5468\u544a\u77e5\u5bf9\u65b9\u3002\u5982\u672a\u80fd\u63d0\u524d\u544a\u77e5\uff0c\u5219\u9700\u652f\u4ed8\u5bf9\u65b9\u8fdd\u7ea6\u91d13000\u5143\u4eba\u6c11\u5e01\u3002\n"}
