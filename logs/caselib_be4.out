2\u964d\u4f4e\u56de\u590d\u95e8\u69db\u3001\u8865\u4e00\u4e2a\u660e\u786e\u4ef7\u503c\u70b9\u3001\u7ed9\u51fa\u4e8c\u9009\u4e00\u3001\u6216\u95ee\u4e00\u4e2a\u987a\u624b\u53ef\u56de\u7684\u77ed\u95ee\u9898\u3002\n5. \u5982\u679c\u5ba2\u6237\u6700\u540e\u4e00\u53e5\u5df2\u7ecf\u56de\u7b54\u4e86\u6211\u65b9\u4e0a\u4e00\u95ee\uff0c**\u7981\u6b62\u628a\u5ba2\u6237\u7684\u786e\u8ba4\u53e5\u6539\u5199\u6210\u53cd\u95ee\u53e5\u518d\u95ee\u56de\u53bb**\u3002\n   - \u4f8b\u5982\u5ba2\u6237\u5df2\u786e\u8ba4\u65f6\u95f4\uff0c\u5c31\u4e0d\u8981\u518d\u95ee\u201c\u8fd9\u4e2a\u65f6\u95f4\u6ca1\u95ee\u9898\u5427/\u662f\u8fd9\u4e2a\u65f6\u95f4\u5417\u201d\uff1b\n   - \u5ba2\u6237\u8bf4\u201c\u5230\u516c\u53f8\u53d1\u4f60/\u7a0d\u540e\u53d1\u4f60\u201d\uff0c\u5c31\u5148\u786e\u8ba4\u6536\u5230\uff0c\u518d\u8bf4\u660e\u6536\u5230\u540e\u7684\u52a8\u4f5c\uff0c\u5fc5\u8981\u65f6\u53ea\u8865\u4e00\u4e2a\u8f7b\u91cf\u4e0b\u4e00\u6b65\uff1b\n   - \u5ba2\u6237\u53ea\u56de\u201c\u6536\u5230/OK/\u597d\u201d\uff0c\u4f18\u5148\u505a\u4f4e\u8d1f\u62c5\u627f\u63a5\uff0c\u4e0d\u8981\u673a\u68b0\u590d\u8ff0\u5ba2\u6237\u539f\u8bdd\u3002\n6. \u5982\u679c\u540c\u65f6\u5b58\u5728\u591a\u4e2a\u65e5\u671f/\u591a\u4e2a\u4f1a\u8bae/\u591a\u4e2a\u4e8b\u9879\uff0c\u53ea\u56de\u5e94\u5f53\u524d\u8fd9\u4e00\u8f6e\u6700\u76f8\u5173\u7684\u4e00\u9879\uff0c\u4e0d\u80fd\u628a 6 \u6708\u4f1a\u8bae\u548c\u672c\u5468\u4e09\u4f1a\u8bae\u6df7\u6210\u4e00\u4e2a\u5b89\u6392\u3002\n7. \u5982\u679c\u6458\u8981\u6216\u5ba2\u6237\u753b\u50cf\u91cc\u5df2\u7ecf\u533a\u5206 `ongoing` \u4e0e `future` \u4e8b\u9879\uff0c\u56de\u590d\u65f6\u8981\u660e\u786e\u77e5\u9053\u54ea\u4e2a\u662f\u5f53\u524d\u6b63\u5728\u63a8\u8fdb\u3001\u54ea\u4e2a\u662f\u540e\u7eed\u5c06\u53d1\u751f\u3002\n8. \u5982\u679c\u7ebf\u7a0b\u72b6\u6001\u91cc\u6709 `latest_sales_message`\uff0c\u628a\u5b83\u89c6\u4e3a\u201c\u521a\u521a\u5df2\u7ecf\u53d1\u51fa\u53bb\u7684\u8bdd\u201d\uff0c\u65b0\u56de\u590d\u5fc5\u987b\u4e0e\u5b83\u6709\u660e\u663e\u5dee\u5f02\u3002\n9. \u5fc5\u987b\u4e25\u683c\u9075\u5faa\u672c\u6b21\u6307\u5b9a\u7684\u56de\u590d\u98ce\u683c\u8981\u6c42\uff0c\u4e0d\u8981\u8f93\u51fa\u98ce\u683c\u8bf4\u660e\u6587\u5b57\u3002\n10. \u8bf7\u6309\u7167\u4e25\u683c\u7684\u683c\u5f0f\u8f93\u51fa\uff1a\n\n\u3010\u4f01\u5fae\u56de\u590d\u53c2\u8003\u3011\n(\u7ed9\u51fa\u4e00\u5230\u4e24\u53e5\u53ef\u4ee5\u76f4\u63a5\u590d\u5236\u53d1\u5fae\u4fe1\u7684\u7b80\u77ed\u8bdd\u672f\uff0c\u4e0d\u8981\u8d85\u8fc750\u5b57)\n\n\u3010\u672c\u6b21\u56de\u590d\u98ce\u683c\u8981\u6c42\u3011:\n\u4eb2\u548c\u5fae\u4fe1\u98ce\n\u8bed\u6c14\u81ea\u7136\u3001\u4eb2\u548c\u3001\u50cf\u5fae\u4fe1\u91cc\u987a\u624b\u53d1\u7684\u77ed\u6d88\u606f\u3002\n\n\u3010\u6458\u8981\u6863\u6848\u3011:\n{\"topic\": \"\u5ba2\u6237\u5c55\u4f1a\u9700\u6c42\u6c9f\u901a\", \"core_demand\": \"\u5ba2\u6237\u786e\u8ba4\u53c2\u52a0\u5c0f\u578b\u884c\u4e1a\u4f1a\u8bae\uff0c\u5c55\u53f0\u9700\u6c42\u4e3a\u9152\u5e97\u5185\u5c0f\u5c55\u53f0\", \"key_facts\": {\"latest_customer_reply_type\": \"other\", \"timeline_items\": [{\"time\": \"\u53bb\u5e749\u6708\", \"topic\": \"\u6a61\u5851\u5c55\u5c55\u53f0\u642d\u5efa\", \"status_scope\": \"future\", \"status\": \"\u5f85\u786e\u8ba4\", \"owner\": \"\u5ba2\u6237\", \"next_action\": \"\u786e\u8ba4\u5ba2\u6237\u662f\u5426\u8ba1\u5212\u53c2\u52a0\u7c7b\u4f3c\u5c0f\u578b\u4f1a\u8bae\"}], \"current_focus\": \"\u5ba2\u6237\u660e\u786e\u8868\u793a\u4e0d\u53c2\u52a0\u5927\u578b\u5c55\u4f1a\uff0c\u53ea\u53c2\u52a0\u9152\u5e97\u5185\u5c0f\u578b\u884c\u4e1a\u4f1a\u8bae\uff0c\u9700\u786e\u8ba4\u5177\u4f53\u4f1a\u8bae\u53ca\u5c55\u53f0\u9700\u6c42\"}, \"todo_items\": [\"\u8be2\u95ee\u5ba2\u6237\u8fd1\u671f\u53c2\u52a0\u7684\u5c0f\u578b\u4f1a\u8bae\u540d\u79f0\u53ca\u65f6\u95f4\", \"\u4e86\u89e3\u5c0f\u5c55\u53f0\u7684\u5177\u4f53\u5c3a\u5bf8\u548c\u642d\u5efa\u8981\u6c42\"], \"risks\": \"[\\\"\u5ba2\u6237\u9884\u7b97\u53ef\u80fd\u8f83\u4f4e\uff0c\u5f71\u54cd\u670d\u52a1\u8303\u56f4\\\", \\\"\u5c0f\u578b\u4f1a\u8bae\u5c55\u53f0\u97