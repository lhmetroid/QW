e0d\u5199\u89e3\u91ca\u8fc7\u7a0b\u3002\n\n\u3010\u4f01\u5fae\u5bf9\u8bdd\u5b9e\u5f55\u3011:\n[\u5ba2\u6237]: \"\u4f55\u73fa: \u8d22\u52a1\u4ed8\u6b3e\u8d26\u53f7\u5199\u9519\u4e86~~\"\n- - - - - - - - - - - - - - -\n\u662f\u4f60\u4eec\u8d22\u52a1\u5199\u9519\u4e86\uff0c\u8fd8\u662f\u6211\u4eec\u8fd9\u8fb9\u641e\u9519\u4e86\uff1f\n[\u9500\u552e]: \u8fd9\u662f\u6e23\u6253\u53d1\u7ed9\u6211\u4eec\u7684\u51ed\u8bc1\uff0c \u9700\u8981\u4f60\u5bb6\u8d22\u52a1\u66f4\u6b63\u54e6\n[\u9500\u552e]: \u8d26\u53f7\u4e0d\u5bf9\uff0c\u5165\u4e0d\u4e86\u5e10\u6ef4\n[\u5ba2\u6237]: \u8fd9\u4e2a\u662f\u4f60\u4eec\u6536\u5230\u7684\u7b2c\u4e00\u7b14\u6b3e\u4e48\uff1f\n[\u5ba2\u6237]: \u4e4b\u524d\u6709\u6ca1\u6709\u9519\uff1f\n[\u5ba2\u6237]: \u6211\u5c31\u6015\u662f\u4e0d\u662f\u4f60\u4eec\u7559\u5728\u7cfb\u7edf\u7684\u8d26\u53f7\u641e\u9519\u4e86\n[\u5ba2\u6237]: \u4f60\u628aPO\u53f7\u53d1\u4e00\u4e0b\u7ed9\u6211\n[\u5ba2\u6237]: \u8fd9\u7b14\u6b3e\u5bf9\u5e94\u7684PO\u53f7\n[\u9500\u552e]: \u6211\u4e5f\u62c5\u5fc3\u662f\u7cfb\u7edf\u91cc\u8d26\u53f7\u9519\u4e86\n[\u9500\u552e]: PO 21329394\n"}
