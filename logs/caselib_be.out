summary_status\": \"\u8c08\u5224\u4e2d\uff0c\u5f85\u9500\u552e\u56de\u590d\u65b0\u62a5\u4ef7\", \"last_sender\": \"sales\", \"sales_message_count\": 4, \"customer_message_count\": 6, \"consecutive_sales_messages\": 1, \"awaiting_customer_reply\": true, \"sales_only_conversation\": false, \"followup_after_no_reply\": false, \"latest_sales_message\": \"\u5982\u679c\u6211\u5f00\u79681%\uff0c\u4f60\u770b\u53ef\u4ee5\u54c7\", \"recent_sales_messages\": [\"6%\u662f\u7a0e\u662f\u53ef\u4ee5\u62b5\u6263\u7684\uff0c1%\u7684\u53d1\u7968\u53ef\u4ee5\u5165\u6210\u672c\uff0c\u5c31\u662f\u7a0e\u91d1\u90e8\u5206\u4e0d\u80fd\u62b5\u6263\", \"\u5982\u679c\u6211\u5f00\u79681%\uff0c\u4f60\u770b\u53ef\u4ee5\u54c7\"], \"latest_customer_message\": \"\u539f\u672c\u76846%\u8ddf\u8fd9\u4e2a1%\u6709\u4ec0\u4e48\u5f71\u54cd\u5417\", \"latest_customer_reply_type\": \"question\", \"crm_has_quote_history\": false}}, \"crm_context\": {}, \"candidates\": [{\"candidate_id\": \"llm2__knowledge_v2__style_1\", \"model_slot\": \"llm2\", \"model_label\": \"\u4e3b\u6a21\u578b\", \"model_display_name\": \"LLM-2 / deepseek-chat\", \"knowledge_source\": \"knowledge_v2\", \"knowledge_source_label\": \"\u77e5\u8bc6\u5e931\", \"style_title\": \"\u4eb2\u548c\u5fae\u4fe1\u98ce\", \"reply_text\": \"\u660e\u767d\uff0c\u90a3\u63091%\u5f00\uff0c\u6211\u91cd\u65b0\u7b97\u4e2a\u4f18\u60e0\u603b\u4ef7\u53d1\u60a8\uff0c\u60a8\u770b\u884c\u4e0d\uff1f\"}], \"actual_sales_replies\": [{\"reply_id\": 66543, \"time\": \"2023-09-11T13:45:09\", \"content\": \"\u54ce\uff0c\u6211\u518d\u6c9f\u901a\u4e0b\u54e6\u3002 \u5c55\u5385\u548c\u5c55\u53f0\u7684\u6750\u6599\u4eba\u5de5\u5176\u5b9e\u76f8\u5dee\u86ee\u591a~~\"}, {\"reply_id\": 66544, \"time\": \"2023-09-11T13:45:31\", \"content\": \"\u5c55\u53f0\u7684\u4e1c\u897f3\u5929\uff0c\u7ed3\u675f\u57fa\u672c\u90fd\u4e22\u4e86[\u5077\u7b11]\"}], \"dimensions\": [\"overall\", \"low_barrier\", \"non_repetition\", \"safety\", \"conciseness\", \"style_match\", \"context_alignment\"]}"}
